# ──────────────────────────────────────────────────────────────────────
# Non-sensitive configuration for the Inception stack.
#
# This file is INTENTIONALLY committed to the repository.
# All CREDENTIALS live in srcs/secrets/ (gitignored) and are injected
# into containers via Docker Secrets.
# ──────────────────────────────────────────────────────────────────────

# Domain
DOMAIN_NAME=jaehylee.42.fr

# Service hostnames and ports (Docker DNS resolves these on the `limbo` network)
DB_HOST=mariadb
DB_PORT=3306
REDIS_HOST=redis
REDIS_PORT=6379
WP_HOST=wordpress
WP_FPM_PORT=9000

# WordPress site config
WP_TITLE=Inception
